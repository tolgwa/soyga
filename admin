	end
end)

Sec:NewToggle("Infinite Jump", "Sürekli zıplamanı sağlar (B tuşu)", function(state)
	getgenv().InfiniteJumpEnabled = state
	setupInfiniteJump()
end)

Sec:NewSlider("Fly Hızı", "Uçuş hızı (20-200)", 200, 20, function(s)
	flyMaxSpeed = s
end)

Sec:NewLabel("F tuşu = Fly | B tuşu = Infinite Jump")

Sec:NewKeybind("Menüyü Gizle/Göster", "Sağ Alt", Enum.KeyCode.RightControl, function()
	Library:ToggleUI()
end)

Sec:NewButton("❌ Scripti ve Menüyü Tamamen Kapat", "Tüm hileleri siler ve normale döndürür", function()
	unloadScript()
end)

-- ==================== HIGHLIGHT (YENİ) ====================
local HighlightTab = Window:NewTab("Highlight")
local HighlightSec = HighlightTab:NewSection("Oyuncu Highlight")
HighlightSec:NewLabel("Açık olan oyuncular yeşil çerçeveyle işaretlenir")
HighlightSec:NewLabel("made by alae")  -- istenen kredi etiketi

-- Highlight işlevleri
local playerHighlightData = {}  -- player -> {toggleObj, charConnection}

local function addHighlightToCharacter(char)
	if char:FindFirstChild("PlayerHighlight") then return end
	local highlight = Instance.new("Highlight")
	highlight.Name = "PlayerHighlight"
	highlight.FillColor = Color3.fromRGB(0, 255, 0)
	highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
	highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	highlight.Parent = char
end

local function removeHighlightFromPlayer(player)
	local char = player.Character
	if char then
		local existing = char:FindFirstChild("PlayerHighlight")
		if existing then existing:Destroy() end
	end
end

local function addPlayerToggle(plr)
	if plr == player then return end -- kendini listeleme
	if playerHighlightData[plr] then return end

	-- toggle'ı oluştur
	local toggleObj = HighlightSec:NewToggle(plr.Name, "Seçiliyken highlight aktif", function(state)
		local data = playerHighlightData[plr]
		if not data then return end

		if state then
			-- highlight ekle
			if plr.Character then
				addHighlightToCharacter(plr.Character)
			end
			-- karakter eklenince tekrar eklenmesi için dinleyici kur
			data.charConnection = plr.CharacterAdded:Connect(function(char)
				addHighlightToCharacter(char)
			end)
		else
			-- highlight kaldır
			removeHighlightFromPlayer(plr)
			if data.charConnection then
				data.charConnection:Disconnect()
				data.charConnection = nil
			end
		end
	end)

	playerHighlightData[plr] = {
		toggleObj = toggleObj,
		charConnection = nil
	}
end

local function removePlayerToggle(plr)
	local data = playerHighlightData[plr]
	if not data then return end

	if data.charConnection then
		data.charConnection:Disconnect()
	end
	-- highlight temizle
	removeHighlightFromPlayer(plr)
	-- UI’daki toggle’ı yok et
	pcall(function() data.toggleObj.ToggleFrame:Destroy() end)
	playerHighlightData[plr] = nil
end

-- Mevcut oyuncuları ekle
for _, p in ipairs(Players:GetPlayers()) do
	addPlayerToggle(p)
end

-- Yeni giren oyuncular
Players.PlayerAdded:Connect(function(plr)
	task.wait(0.5)
	addPlayerToggle(plr)
end)

-- Ayrılan oyuncuları temizle
Players.PlayerRemoving:Connect(function(plr)
	removePlayerToggle(plr)
end)

--// ==================== UNLOAD ====================
function unloadScript()
	if flying then stopFly() end
	stopNoclip()
	if jumpRequestConn then jumpRequestConn:Disconnect() jumpRequestConn = nil end

	getgenv().SpeedEnabled = false
	getgenv().AntiSlide = false
	getgenv().NoclipEnabled = false
	getgenv().InfiniteJumpEnabled = false

	if currentHum then currentHum.WalkSpeed = 16 end
	if currentRoot then 
		currentRoot.CustomPhysicalProperties = PhysicalProperties.new(0.7, 0.3, 0.5) 
	end

	if mainLoopConn then mainLoopConn:Disconnect() end
	if flyToggleConn then flyToggleConn:Disconnect() end
	if charAddedConn then charAddedConn:Disconnect() end
	if noclipConnection then noclipConnection:Disconnect() end

	for _, conn in ipairs(characterConnections) do
		pcall(function() conn:Disconnect() end)
	end

	-- Highlight cleanup (tüm verileri sil)
	for plr, data in pairs(playerHighlightData) do
		if data.charConnection then data.charConnection:Disconnect() end
		pcall(function() data.toggleObj.ToggleFrame:Destroy() end)
	end
	table.clear(playerHighlightData)

	-- Kavo UI temizleme
	local targetGui = (gethui and gethui()) or game:GetService("CoreGui")
	for _, v in pairs(targetGui:GetChildren()) do
		if v:IsA("ScreenGui") and v.Name == "Kavo" then
			v:Destroy()
		end
	end
end

--// BAŞLANGIÇ
if player.Character then
	setupCharacter(player.Character)
end

charAddedConn = player.CharacterAdded:Connect(setupCharacter)

print("✅ Kontrol Paneli + Noclip + Infinite Jump + Highlight Yüklendi! (F=Fly | B=Infinite Jump)")
