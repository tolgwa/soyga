--// SERVICES
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UIS = game:GetService("UserInputService")
local player = Players.LocalPlayer

--// VARIABLES
getgenv().WalkSpeedValue = 16
getgenv().SpeedEnabled = false          -- Başlangıçta kapalı
getgenv().AntiSlide = false             -- Başlangıçta kapalı
getgenv().FlyEnabled = false
getgenv().NoclipEnabled = false
getgenv().InfiniteJumpEnabled = true

--// STATE & CONNECTIONS
local currentRoot = nil
local currentHum = nil
local characterConnections = {}
local mainLoopConn = nil
local flyToggleConn = nil
local charAddedConn = nil
local noclipConnection = nil
local jumpRequestConn = nil

--// FLY STATE
local flying = false
local flyBG = nil
local flyBV = nil
local flyCtrl = {f = 0, b = 0, l = 0, r = 0}
local flyMaxSpeed = 80
local flyInputBegan = nil
local flyInputEnded = nil

--// ==================== INFINITE JUMP ====================
local function setupInfiniteJump()
	if jumpRequestConn then
		jumpRequestConn:Disconnect()
		jumpRequestConn = nil
	end
	
	if getgenv().InfiniteJumpEnabled and currentHum and currentHum.Health > 0 then
		jumpRequestConn = UIS.JumpRequest:Connect(function()
			if getgenv().InfiniteJumpEnabled and currentHum and currentHum.Health > 0 then
				currentHum:ChangeState(Enum.HumanoidStateType.Jumping)
			end
		end)
	end
end

--// B TUŞU - INFINITE JUMP TOGGLE
UIS.InputBegan:Connect(function(input, processed)
	if processed then return end
	if input.KeyCode == Enum.KeyCode.B then
		getgenv().InfiniteJumpEnabled = not getgenv().InfiniteJumpEnabled
		print("Infinite Jump: " .. tostring(getgenv().InfiniteJumpEnabled))
		setupInfiniteJump()
	end
end)

--// ==================== FLY FONKSİYONLARI ====================
local function startFly()
	local char = player.Character
	if not char then return end
	local humanoid = char:FindFirstChildOfClass("Humanoid")
	local rootPart = char:FindFirstChild("HumanoidRootPart")
	if not humanoid or not rootPart then return end

	flying = true
	char.Animate.Disabled = true

	for _, track in pairs(humanoid:GetPlayingAnimationTracks()) do
		track:AdjustSpeed(0)
	end

	for _, state in pairs(Enum.HumanoidStateType:GetEnumItems()) do
		pcall(function() humanoid:SetStateEnabled(state, false) end)
	end

	humanoid:ChangeState(Enum.HumanoidStateType.Swimming)
	humanoid.PlatformStand = true

	local torso = char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
	if not torso then return end

	flyBG = Instance.new("BodyGyro", torso)
	flyBG.P = 9e4
	flyBG.maxTorque = Vector3.new(9e9, 9e9, 9e9)
	flyBG.CFrame = torso.CFrame

	flyBV = Instance.new("BodyVelocity", torso)
	flyBV.Velocity = Vector3.new(0, 0, 0)
	flyBV.MaxForce = Vector3.new(9e9, 9e9, 9e9)

	flyInputBegan = UIS.InputBegan:Connect(function(input, processed)
		if processed then return end
		if input.KeyCode == Enum.KeyCode.W then flyCtrl.f = 1 end
		if input.KeyCode == Enum.KeyCode.S then flyCtrl.b = -1 end
		if input.KeyCode == Enum.KeyCode.A then flyCtrl.l = -1 end
		if input.KeyCode == Enum.KeyCode.D then flyCtrl.r = 1 end
	end)

	flyInputEnded = UIS.InputEnded:Connect(function(input)
		if input.KeyCode == Enum.KeyCode.W then flyCtrl.f = 0 end
		if input.KeyCode == Enum.KeyCode.S then flyCtrl.b = 0 end
		if input.KeyCode == Enum.KeyCode.A then flyCtrl.l = 0 end
		if input.KeyCode == Enum.KeyCode.D then flyCtrl.r = 0 end
	end)

	spawn(function()
		while flying and humanoid and humanoid.Parent and humanoid.Health > 0 do
			RunService.RenderStepped:Wait()
			local cam = workspace.CurrentCamera

			if flyCtrl.l + flyCtrl.r ~= 0 or flyCtrl.f + flyCtrl.b ~= 0 then
				flyBV.Velocity = ((cam.CFrame.LookVector * (flyCtrl.f + flyCtrl.b)) + 
				                 (cam.CFrame * CFrame.new(flyCtrl.l + flyCtrl.r, (flyCtrl.f + flyCtrl.b) * 0.2, 0)).Position - cam.CFrame.Position) * flyMaxSpeed
			else
				flyBV.Velocity = Vector3.new(0, 0, 0)
			end

			flyBG.CFrame = cam.CFrame * CFrame.Angles(-math.rad((flyCtrl.f + flyCtrl.b) * 50), 0, 0)
		end
	end)
end

local function stopFly()
	flying = false
	if flyBG then flyBG:Destroy() flyBG = nil end
	if flyBV then flyBV:Destroy() flyBV = nil end
	if flyInputBegan then flyInputBegan:Disconnect() flyInputBegan = nil end
	if flyInputEnded then flyInputEnded:Disconnect() flyInputEnded = nil end

	local char = player.Character
	if char then
		local humanoid = char:FindFirstChildOfClass("Humanoid")
		if humanoid then
			humanoid.PlatformStand = false
			for _, state in pairs(Enum.HumanoidStateType:GetEnumItems()) do
				pcall(function() humanoid:SetStateEnabled(state, true) end)
			end
			humanoid:ChangeState(Enum.HumanoidStateType.RunningNoPhysics)
		end
		pcall(function() char.Animate.Disabled = false end)
	end
end

--// ==================== NOCLIP ====================
local function startNoclip()
	if noclipConnection then return end
	
	noclipConnection = RunService.Stepped:Connect(function()
		if not getgenv().NoclipEnabled then
			noclipConnection:Disconnect()
			noclipConnection = nil
			return
		end

		local char = player.Character
		if char then
			for _, v in pairs(char:GetDescendants()) do
				if v:IsA("BasePart") then
					v.CanCollide = false
				end
			end
		end
	end)
end

local function stopNoclip()
	getgenv().NoclipEnabled = false
	if noclipConnection then
		noclipConnection:Disconnect()
		noclipConnection = nil
	end
end

--// ==================== HAREKET AYARLARI ====================
local function applyMovementSettings(char)
	for _, conn in ipairs(characterConnections) do pcall(function() conn:Disconnect() end) end
	table.clear(characterConnections)

	local hum = char:WaitForChild("Humanoid", 5)
	local root = char:WaitForChild("HumanoidRootPart", 5)
	if not hum or not root then return end

	currentHum = hum
	currentRoot = root

	if getgenv().SpeedEnabled then
		hum.WalkSpeed = getgenv().WalkSpeedValue
	end

	if getgenv().AntiSlide then
		root.CustomPhysicalProperties = PhysicalProperties.new(100, 0.45, 0.5, 1, 1)
	end

	if getgenv().NoclipEnabled then
		startNoclip()
	end

	setupInfiniteJump()

	local diedConn = hum.Died:Connect(function()
		currentHum = nil
		currentRoot = nil
		if flying then stopFly() end
		stopNoclip()
		if jumpRequestConn then jumpRequestConn:Disconnect() jumpRequestConn = nil end
		for _, conn in ipairs(characterConnections) do pcall(function() conn:Disconnect() end) end
		table.clear(characterConnections)
	end)
	table.insert(characterConnections, diedConn)
end

local function setupCharacter(char)
	task.wait(0.25)
	if flying then stopFly() end
	applyMovementSettings(char)
end

--// ANA LOOP
mainLoopConn = RunService.Heartbeat:Connect(function()
	if not currentHum or not currentRoot then return end

	if not flying and getgenv().SpeedEnabled and currentHum.WalkSpeed ~= getgenv().WalkSpeedValue then
		currentHum.WalkSpeed = getgenv().WalkSpeedValue
	end

	if not flying and getgenv().AntiSlide then
		local moveMag = currentHum.MoveDirection.Magnitude
		if moveMag < 0.1 then
			local vel = currentRoot.AssemblyLinearVelocity
			if math.abs(vel.X) > 0.05 or math.abs(vel.Z) > 0.05 then
				currentRoot.AssemblyLinearVelocity = Vector3.new(0, vel.Y, 0)
			end
		end
	end
end)

--// F TUŞU FLY
flyToggleConn = UIS.InputBegan:Connect(function(input, processed)
	if processed then return end
	if input.KeyCode == Enum.KeyCode.F then
		if flying then
			stopFly()
		else
			startFly()
		end
	end
end)

