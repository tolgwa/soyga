		currentHum.WalkSpeed = getgenv().WalkSpeedValue
	end
end)

Sec:NewSlider("Hız Ayarı", "Karakter hızı (16-500)", 500, 16, function(s)
	getgenv().WalkSpeedValue = s
	if currentHum and getgenv().SpeedEnabled then
		currentHum.WalkSpeed = s
	end
end)

Sec:NewToggle("Ani Durma (Anti-Slide)", "Durduğunda kaymayı keser", function(state)
